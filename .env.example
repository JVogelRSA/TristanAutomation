# Email Settings (IMAP)
# For Gmail, you MUST use an App Password: https://support.google.com/accounts/answer/185833
IMAP_SERVER=imap.gmail.com
IMAP_USERNAME=your_email@gmail.com
IMAP_PASSWORD=your_app_password

# Email Settings (SMTP - for sending the report)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
# The email address to send the report TO
REPORT_RECIPIENT=boss@example.com

# LLM Settings
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Search Criteria
# The subject line or sender to look for to identify the DCL inventory email
EMAIL_SUBJECT_KEYWORD="Items Status"
EMAIL_SENDER="reports@notifications.dclcorp.com"

# Spend Analysis Credentials
BREX_API_KEY=
MERCURY_API_KEY=
RIPPLING_API_KEY=

# Snowflake Credentials (Sales Summary)
# Preferred: key-pair auth (no 2FA needed)
SNOWFLAKE_USER=daylight_automation
SNOWFLAKE_ACCOUNT=jfhpfej-apb17944
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=DAYLIGHT_SALES
SNOWFLAKE_SCHEMA=CONNECTORS
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/snowflake_key.p8
